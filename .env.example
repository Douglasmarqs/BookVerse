# Copie este arquivo para ".env" e preencha com as credenciais do SEU
# projeto Firebase (Console Firebase > Configurações do projeto > Geral
# > "Seus apps" > Configuração do SDK).
#
# Nunca cometa o arquivo ".env" real no Git — ele já está no .gitignore.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
