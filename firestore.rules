rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidBook(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 300
        && data.author is string && data.author.size() < 300
        && data.totalPages is number && data.totalPages >= 0 && data.totalPages <= 5000
        && data.currentPage is number && data.currentPage >= 0
        && (data.totalPages == 0 || data.currentPage <= data.totalPages)
        && data.status in ['quero_ler', 'lendo', 'concluido'];
    }

    match /users/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.stats.pagesRead == 0
        && request.resource.data.stats.streakCount == 0
        && request.resource.data.stats.booksFinished == 0;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['stats']);

      match /books/{bookId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;

        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && isValidBook(request.resource.data);
      }

      match /readingLog/{logId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /friends/{friendUid} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
      }

      match /friendRequests/{fromUid} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == fromUid;
        allow update: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}